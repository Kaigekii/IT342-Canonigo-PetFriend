<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CREATE ACCOUNT"
            android:textSize="20sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp" />

        <!-- Profile Circle -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/circle_white"
            android:layout_marginBottom="24dp" />

        <!-- Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="PET OWNER"
            android:textSize="12sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:background="@drawable/button_owner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="32dp" />

        <!-- First Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="First Name"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etFirstName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="John"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Last Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Name"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLastName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="Doe"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="you@example.com"
            android:inputType="textEmailAddress"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="Create a strong password"
            android:inputType="textPassword"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Must be at least 8 characters with 1 uppercase, 1 number, and 1 special character"
            android:textSize="12sp"
            android:textColor="@color/gray_light"
            android:layout_marginBottom="16dp" />

        <!-- Confirm Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="Re-enter your password"
            android:inputType="textPassword"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Phone Number (Optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number (Optional)"
            android:textSize="14sp"
            android:textColor="@color/gray_border"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="+1 234 567 8900"
            android:inputType="phone"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Address (Optional) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address (Optional)"
            android:textSize="14sp"
            android:textColor="@color/gray_border"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field"
            android:padding="12dp"
            android:hint="123 Main Street"
            android:textColorHint="@color/gray_light"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Register Button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textSize="16sp"
            android:textColor="@color/gray_dark"
            android:textStyle="bold"
            android:background="@drawable/button_owner"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false" />

        <!-- Already have account -->
        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Already have an account? Sign in"
            android:textSize="13sp"
            android:textColor="@color/gray_border"
            android:fontFamily="sans-serif"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
